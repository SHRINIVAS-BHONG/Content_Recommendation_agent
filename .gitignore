# ── Python ────────────────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.egg-info/
dist/
build/

# ── Virtual environment ───────────────────────────────────────────────────
.venv/
venv/

# ── Environment variables ─────────────────────────────────────────────────
.env

# ── ML models (large binary files — regenerate with scripts/train_model.py)
*.pkl

# ── Datasets (large — regenerate with the Jupyter notebooks in data/)
data/*.csv
data/*.json
data/*.ipynb

# Keep the data/ folder itself in the repo
!data/.gitkeep

# ── Frontend build output & dependencies ─────────────────────────────────
frontend/node_modules/
frontend/dist/
frontend/dist-ssr/
frontend/*.local

# ── WSL Zone.Identifier artifacts ────────────────────────────────────────
*Zone.Identifier
*:Zone.Identifier

# ── IDE / Editor ──────────────────────────────────────────────────────────
.vscode/
.cursor/
.kiro/
.idea/
*.suo
*.sw?
.DS_Store

# ── Testing / coverage ────────────────────────────────────────────────────
.hypothesis/
.pytest_cache/
htmlcov/
.coverage

# ── Logs ──────────────────────────────────────────────────────────────────
*.log
logs/

# ── Misc ──────────────────────────────────────────────────────────────────
CODEBASE.md
